{
  "pv": {
    "name": "NASA Open Source Catalog - Submission Workflow",
    "version": "1.0.0",
    "markdown": ".principal-views/submission-workflow/submission-workflow.md"
  },
  "nodes": [
    {
      "id": "submission-received",
      "type": "otel-event",
      "label": "Submission Received",
      "x": 100,
      "y": 300,
      "width": 200,
      "height": 100,
      "color": "#E67E22",
      "pv": {
        "status": "draft",
        "description": "Triggered when a new project submission is received through any channel",
        "event": {
          "name": "catalog.submission.received",
          "attributes": {
            "submission.source": "github_pr | web_form | robot_branch",
            "submission.project_name": "string",
            "submission.nasa_center": "string"
          }
        }
      }
    },
    {
      "id": "submission-processing-span",
      "type": "otel-span-convention",
      "label": "Process Submission",
      "x": 400,
      "y": 250,
      "width": 250,
      "height": 200,
      "color": "#3498DB",
      "pv": {
        "status": "draft",
        "name": "catalog.submission.process",
        "description": "Parent span covering the entire submission processing lifecycle",
        "otel": {
          "spanPattern": "catalog.submission.process",
          "spanKind": "internal"
        }
      }
    },
    {
      "id": "validation-started",
      "type": "otel-event",
      "label": "Validation Started",
      "x": 450,
      "y": 100,
      "width": 180,
      "height": 80,
      "color": "#9B59B6",
      "pv": {
        "status": "draft",
        "description": "CI/CD pipeline begins validation",
        "event": {
          "name": "catalog.validation.started",
          "attributes": {
            "validator": "travis_ci",
            "commit.sha": "string"
          }
        }
      }
    },
    {
      "id": "schema-validation-span",
      "type": "otel-span-convention",
      "label": "Validate Schema",
      "x": 750,
      "y": 150,
      "width": 220,
      "height": 120,
      "color": "#27AE60",
      "pv": {
        "status": "draft",
        "name": "catalog.schema.validate",
        "description": "Schema validation against code-nasa-schema.json",
        "otel": {
          "spanPattern": "catalog.schema.validate",
          "spanKind": "internal"
        }
      }
    },
    {
      "id": "validation-completed",
      "type": "otel-event",
      "label": "Validation Completed",
      "x": 1050,
      "y": 180,
      "width": 180,
      "height": 80,
      "color": "#27AE60",
      "pv": {
        "status": "draft",
        "description": "Schema validation completes with result",
        "event": {
          "name": "catalog.validation.completed",
          "attributes": {
            "validation.result": "success | failure",
            "validation.errors": "array",
            "validation.duration_ms": "integer"
          }
        }
      }
    },
    {
      "id": "data-persistence-span",
      "type": "otel-span-convention",
      "label": "Persist Data",
      "x": 750,
      "y": 320,
      "width": 220,
      "height": 120,
      "color": "#5CB85C",
      "pv": {
        "status": "draft",
        "name": "catalog.data.persist",
        "description": "Writing data to catalog.json, code.json, and code-history.json",
        "otel": {
          "spanPattern": "catalog.data.persist",
          "spanKind": "internal"
        }
      }
    },
    {
      "id": "merge-completed",
      "type": "otel-event",
      "label": "Submission Merged",
      "x": 450,
      "y": 500,
      "width": 180,
      "height": 80,
      "color": "#3498DB",
      "pv": {
        "status": "draft",
        "description": "Submission successfully merged to master branch",
        "event": {
          "name": "catalog.submission.merged",
          "attributes": {
            "git.branch": "master",
            "git.commit_sha": "string",
            "merge.author": "string"
          }
        }
      }
    },
    {
      "id": "publication-span",
      "type": "otel-span-convention",
      "label": "Execute Publication",
      "x": 750,
      "y": 480,
      "width": 250,
      "height": 220,
      "color": "#9B59B6",
      "pv": {
        "status": "draft",
        "name": "catalog.publication.execute",
        "description": "Parent span for publishing to external portals",
        "otel": {
          "spanPattern": "catalog.publication.execute",
          "spanKind": "client"
        }
      }
    },
    {
      "id": "publish-nasa-span",
      "type": "otel-span-convention",
      "label": "Publish to NASA Portal",
      "x": 1100,
      "y": 500,
      "width": 200,
      "height": 80,
      "color": "#3498DB",
      "pv": {
        "status": "draft",
        "name": "catalog.publish.code_nasa_gov",
        "description": "Publish to code.nasa.gov portal",
        "otel": {
          "spanPattern": "catalog.publish.code_nasa_gov",
          "spanKind": "client"
        }
      }
    },
    {
      "id": "publish-federal-span",
      "type": "otel-span-convention",
      "label": "Publish to Federal Portal",
      "x": 1100,
      "y": 600,
      "width": 200,
      "height": 80,
      "color": "#95A5A6",
      "pv": {
        "status": "draft",
        "name": "catalog.publish.code_gov",
        "description": "Publish to federal code.gov registry",
        "otel": {
          "spanPattern": "catalog.publish.code_gov",
          "spanKind": "client"
        }
      }
    },
    {
      "id": "publication-completed",
      "type": "otel-event",
      "label": "Publication Completed",
      "x": 1380,
      "y": 550,
      "width": 180,
      "height": 80,
      "color": "#27AE60",
      "pv": {
        "status": "draft",
        "description": "Publication to all portals completed successfully",
        "event": {
          "name": "catalog.publication.completed",
          "attributes": {
            "publication.success": "boolean",
            "publication.portals": "array",
            "publication.timestamp": "datetime"
          }
        }
      }
    },
    {
      "id": "history-recorded",
      "type": "otel-event",
      "label": "History Recorded",
      "x": 750,
      "y": 750,
      "width": 180,
      "height": 80,
      "color": "#5BC0DE",
      "pv": {
        "status": "draft",
        "description": "Version snapshot recorded in code-history.json",
        "event": {
          "name": "catalog.history.recorded",
          "attributes": {
            "history.file": "code-history.json",
            "history.uuid": "string",
            "history.snapshot_size": "integer"
          }
        }
      }
    },
    {
      "id": "catalog-service-resource",
      "type": "otel-resource",
      "label": "Catalog Service",
      "x": 100,
      "y": 50,
      "width": 250,
      "height": 120,
      "color": "#34495E",
      "pv": {
        "status": "draft",
        "description": "OTEL resource representing the catalog service"
      }
    }
  ],
  "edges": [
    {
      "id": "e1",
      "fromNode": "submission-received",
      "toNode": "submission-processing-span",
      "fromSide": "right",
      "toSide": "left",
      "label": "initiates"
    },
    {
      "id": "e2",
      "fromNode": "submission-processing-span",
      "toNode": "validation-started",
      "fromSide": "top",
      "toSide": "bottom",
      "label": "triggers"
    },
    {
      "id": "e3",
      "fromNode": "validation-started",
      "toNode": "schema-validation-span",
      "fromSide": "right",
      "toSide": "left",
      "label": "starts"
    },
    {
      "id": "e4",
      "fromNode": "schema-validation-span",
      "toNode": "validation-completed",
      "fromSide": "right",
      "toSide": "left",
      "label": "emits"
    },
    {
      "id": "e5",
      "fromNode": "submission-processing-span",
      "toNode": "data-persistence-span",
      "fromSide": "right",
      "toSide": "left",
      "label": "child span"
    },
    {
      "id": "e6",
      "fromNode": "submission-processing-span",
      "toNode": "merge-completed",
      "fromSide": "bottom",
      "toSide": "top",
      "label": "emits on success"
    },
    {
      "id": "e7",
      "fromNode": "merge-completed",
      "toNode": "publication-span",
      "fromSide": "right",
      "toSide": "left",
      "label": "triggers"
    },
    {
      "id": "e8",
      "fromNode": "publication-span",
      "toNode": "publish-nasa-span",
      "fromSide": "right",
      "toSide": "left",
      "label": "child span"
    },
    {
      "id": "e9",
      "fromNode": "publication-span",
      "toNode": "publish-federal-span",
      "fromSide": "right",
      "toSide": "left",
      "label": "child span"
    },
    {
      "id": "e10",
      "fromNode": "publish-nasa-span",
      "toNode": "publication-completed",
      "fromSide": "right",
      "toSide": "left",
      "label": "contributes to"
    },
    {
      "id": "e11",
      "fromNode": "publish-federal-span",
      "toNode": "publication-completed",
      "fromSide": "right",
      "toSide": "left",
      "label": "contributes to"
    },
    {
      "id": "e12",
      "fromNode": "data-persistence-span",
      "toNode": "history-recorded",
      "fromSide": "bottom",
      "toSide": "top",
      "label": "emits"
    },
    {
      "id": "e13",
      "fromNode": "catalog-service-resource",
      "toNode": "submission-processing-span",
      "fromSide": "bottom",
      "toSide": "top",
      "label": "context"
    }
  ]
}
