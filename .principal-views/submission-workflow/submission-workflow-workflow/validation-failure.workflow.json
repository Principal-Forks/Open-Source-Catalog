{
  "name": "Validation Failure",
  "description": "Submission fails schema validation and is rejected",
  "canvas": ".principal-views/submission-workflow/submission-workflow.otel.canvas",
  "scenarios": [
    {
      "name": "Schema Validation Fails",
      "description": "Submission rejected due to schema violations",
      "steps": [
        {
          "event": "catalog.submission.received",
          "description": "New project submission received",
          "highlightNodes": ["submission-received"],
          "color": "#E67E22"
        },
        {
          "span": "catalog.submission.process",
          "description": "Begin processing the submission",
          "highlightNodes": ["submission-processing-span"],
          "color": "#3498DB"
        },
        {
          "event": "catalog.validation.started",
          "description": "Travis CI initiates validation",
          "highlightNodes": ["validation-started", "submission-processing-span"],
          "color": "#9B59B6"
        },
        {
          "span": "catalog.schema.validate",
          "description": "Validate against code-nasa-schema.json",
          "highlightNodes": ["schema-validation-span", "submission-processing-span"],
          "color": "#27AE60"
        },
        {
          "event": "catalog.validation.completed",
          "description": "Schema validation FAILS - submission rejected",
          "highlightNodes": ["validation-completed", "submission-processing-span"],
          "color": "#E74C3C"
        }
      ]
    }
  ]
}
